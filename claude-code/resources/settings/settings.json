{
  "permissions": {
    "ask": [
      "Edit(./**/appsettings*.json)", "Write(./**/appsettings*.json)",
      "Edit(./**/*.env)", "Write(./**/*.env)",
      "Edit(./**/*.env.*)", "Write(./**/*.env.*)",
      "Edit(./docker-compose*.yml)", "Write(./docker-compose*.yml)",
      "Edit(./**/*.pfx)", "Write(./**/*.pfx)",
      "Edit(./**/*.pem)", "Write(./**/*.pem)",
      "Edit(./**/*.tfvars)", "Write(./**/*.tfvars)"
    ]
  }
}
